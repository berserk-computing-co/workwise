# Server
PORT=4000
CORS_ORIGIN=http://localhost:3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=workwise_dev
DB_USERNAME=
DB_PASSWORD=

# Redis (defaults to localhost:6379 if omitted)
REDIS_HOST=localhost
REDIS_PORT=6379
