# Stytch
STYTCH_PROJECT_ID=
STYTCH_PROJECT_ENV=test
STYTCH_SECRET=

# Anthropic
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=

# AWS S3 (credentials from ~/.aws/credentials)
AWS_REGION=us-west-1
S3_BUCKET_NAME=workwise-haiku
