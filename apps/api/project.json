{
  "name": "api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/api/src",
  "projectType": "application",
  "tags": ["type:app", "scope:backend"],
  "targets": {
    "check-types": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx tsc --noEmit",
        "cwd": "apps/api"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "npx nest build",
        "cwd": "apps/api"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx nest start --watch",
        "cwd": "apps/api"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/coverage"],
      "options": {
        "command": "npx jest",
        "cwd": "apps/api"
      }
    },
    "migration:run": {
      "executor": "nx:run-commands",
      "cache": false,
      "options": {
        "command": "npx tsx ../../node_modules/typeorm/cli.js -d src/data-source.ts migration:run",
        "cwd": "apps/api"
      }
    },
    "migration:revert": {
      "executor": "nx:run-commands",
      "cache": false,
      "options": {
        "command": "npx tsx ../../node_modules/typeorm/cli.js -d src/data-source.ts migration:revert",
        "cwd": "apps/api"
      }
    },
    "migration:generate": {
      "executor": "nx:run-commands",
      "cache": false,
      "options": {
        "command": "npx tsx ../../node_modules/typeorm/cli.js -d src/data-source.ts migration:generate src/migrations/{args.name}",
        "cwd": "apps/api"
      }
    }
  }
}
